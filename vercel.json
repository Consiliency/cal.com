{
  "buildCommand": "yarn turbo run post-install && yarn workspace @calcom/web build",
  "outputDirectory": "apps/web/.next",
  "installCommand": "yarn install --mode=skip-build",
  "framework": "nextjs",
  "regions": ["iad1"],
  "functions": {
    "apps/web/pages/api/cron/*.ts": {
      "maxDuration": 60
    }
  },
  "env": {
    "NEXT_TELEMETRY_DISABLED": "1"
  }
}
